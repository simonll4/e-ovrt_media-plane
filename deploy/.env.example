# Copiar a .env y ajustar. Selecciona qué config monta cada nodo.
# Test local: dejar los defaults (apuntan a los *.example.yaml).
# Deploy real: usar el manifiesto del host correspondiente y apuntar a un config
# propio en /app/deploy-configs; en Nodo B editar transport.endpoint al IP del edge.
NODE_A_CONFIG=/app/deploy-configs/two_node_a.example.yaml
NODE_B_CONFIG=/app/deploy-configs/two_node_b.example.yaml
